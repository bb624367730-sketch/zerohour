# Sui network: mainnet or testnet
SUI_NETWORK=testnet

# Contract addresses (from frontend/src/constants.ts)
PACKAGE_ID=0x94aa21ca8cdd301b40a0395128ac78b755014feb2e3386f5dedef77ba9513976
GAME_OBJECT_ID=0xd0080358ecee99bb36dc7cb081fb3e89d88c5196f2c70445639316d2784072fe

# Twitter auth: recommended method is auth_token from browser
# Run `node get-cookie.cjs` to auto-extract, or manually paste below
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# Proxy URL for HTTP requests (v2rayN etc.)
# PROXY_URL=http://127.0.0.1:10809

# Polling interval in milliseconds (default: 10000 = 10s)
POLL_INTERVAL_MS=10000

# Dry run mode: logs tweets instead of posting (default: true, set to false to actually post)
DRY_RUN=true
